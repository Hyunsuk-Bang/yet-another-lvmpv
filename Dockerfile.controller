FROM golang:1.23 AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o lvmpv .

# Controller only talks to the Kubernetes API — no LVM tools needed.
# distroless/static gives us a minimal, read-only root filesystem.
FROM gcr.io/distroless/static:nonroot
COPY --from=builder /app/lvmpv /lvmpv
ENTRYPOINT ["/lvmpv"]
